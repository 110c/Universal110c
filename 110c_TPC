local currentKeybind = Enum.KeyCode.Slash
local settingKeybind = false

local function teleportToMouse()
    local mouse = lp:GetMouse()
    local ray = camera:ScreenPointToRay(mouse.X, mouse.Y)
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {lp.Character or {}}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.IgnoreWater = true

    local result = Workspace:Raycast(ray.Origin, ray.Direction * 2000, rayParams)
    if result and result.Position then
        local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.CFrame = CFrame.new(result.Position + Vector3.new(0, 3.5, 0))
        end
    end
end

keybindBtn.MouseButton1Click:Connect(function()
    settingKeybind = true
    keybindBtn.Text = "..."
    keybindBtn.BackgroundColor3 = Color3.fromRGB(100, 60, 60)
end)

selectorBtn.MouseButton1Click:Connect(function()
    selectedMouseButton = (selectedMouseButton + 1) % 3
    if selectedMouseButton == 0 then
        selectorBtn.Text = "Mouse: Left Click ▼"
    elseif selectedMouseButton == 1 then
        selectorBtn.Text = "Mouse: Right Click ▼"
    else
        selectorBtn.Text = "Mouse: Scroll Wheel ▼"
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if settingKeybind then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            currentKeybind = input.KeyCode
            keyLabel.Text = "Key: " .. currentKeybind.Name
            settingKeybind = false
            keybindBtn.Text = "Set"
            keybindBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 100)
        end
        return
    end

    if input.KeyCode == currentKeybind then
        clickTpEnabled = not clickTpEnabled
        status.Text = "Click TP: " .. (clickTpEnabled and "ON" or "OFF")
        status.TextColor3 = clickTpEnabled and Color3.fromRGB(90,255,90) or Color3.fromRGB(255,90,90)
        return
    end

    if not clickTpEnabled then return end

    local trigger = false
    if selectedMouseButton == 0 and input.UserInputType == Enum.UserInputType.MouseButton1 then
        trigger = true
    elseif selectedMouseButton == 1 and input.UserInputType == Enum.UserInputType.MouseButton2 then
        trigger = true
    elseif selectedMouseButton == 2 and input.UserInputType == Enum.UserInputType.MouseButton3 then
        trigger = true
    end

    if trigger then
        teleportToMouse()
    end
end)
