local delayTime = 10
local afkEnabled = true

local function jump()
    if humanoid and humanoid.Health > 0 then
        humanoid.Jump = true
        task.delay(0.05, function() if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end end)
    end
end

task.spawn(function()
    while true do
        if afkEnabled then jump() end
        task.wait(delayTime)
    end
end)

afkToggle.MouseButton1Click:Connect(function()
    afkEnabled = not afkEnabled
    afkToggle.BackgroundColor3 = afkEnabled and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
    afkToggle.Text = afkEnabled and "ON" or "OFF"
end)

