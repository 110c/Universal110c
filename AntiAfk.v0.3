local countdownRunning = false
local countdownTime = 300

local function formatTime(seconds)
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = seconds % 60
    return string.format("%02d:%02d:%02d", h, m, s)
end

timeBox.Text = formatTime(countdownTime)

timeBox.FocusLost:Connect(function()
    if not countdownRunning then
        local text = timeBox.Text:gsub(":", "")
        local num = tonumber(text) or 0
        num = math.clamp(num, 0, 995959)
        local h = math.floor(num / 10000)
        local m = math.floor((num % 10000) / 100)
        local s = num % 100
        countdownTime = h*3600 + m*60 + s
        timeBox.Text = formatTime(countdownTime)
    end
end)

timerStartBtn.MouseButton1Click:Connect(function()
    if countdownRunning then
        countdownRunning = false
        timerStartBtn.Text = "START"
        timerStartBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        timeBox.TextEditable = true
    else
        if countdownTime > 0 then
            countdownRunning = true
            timerStartBtn.Text = "STOP"
            timerStartBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
            timeBox.TextEditable = false
        end
    end
end)

timerResetBtn.MouseButton1Click:Connect(function()
    if not countdownRunning then
        countdownTime = 0
        timeBox.Text = "00:00:00"
        timerStartBtn.Text = "START"
        timerStartBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        timeBox.TextEditable = true
    end
end)

task.spawn(function()
    while true do
        if countdownRunning and countdownTime > 0 then
            countdownTime -= 1
            timeBox.Text = formatTime(countdownTime)
            if countdownTime <= 0 then
                countdownRunning = false
                timerStartBtn.Text = "START"
                timerStartBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
                timeBox.TextEditable = true
            end
        end
        task.wait(1)
    end
end)
