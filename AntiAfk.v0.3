local swRunning = false
local swStartTime = 0
local swPausedTime = 0

local function swFormatTime()
    local elapsed = swRunning and (os.clock() - swStartTime) or swPausedTime
    local h = math.floor(elapsed / 3600)
    local m = math.floor((elapsed % 3600) / 60)
    local s = math.floor(elapsed % 60)
    local ms = math.floor((elapsed % 1) * 100)
    return string.format("%02d:%02d:%02d.%02d", h, m, s, ms)
end

task.spawn(function()
    while true do
        if swRunning then swTimeLabel.Text = swFormatTime() end
        task.wait(0.01)
    end
end)

swStartBtn.MouseButton1Click:Connect(function()
    if swRunning then
        swPausedTime = os.clock() - swStartTime
        swRunning = false
        swStartBtn.Text = "RESUME"
        swStartBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    else
        swStartTime = os.clock() - swPausedTime
        swRunning = true
        swStartBtn.Text = "PAUSE"
        swStartBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    end
end)

swResetBtn.MouseButton1Click:Connect(function()
    if not swRunning then
        swPausedTime = 0
        swTimeLabel.Text = "00:00:00.00"
        swStartBtn.Text = "START"
        swStartBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    end
end)

