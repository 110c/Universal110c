local function stripEverything()
    removeBtn.Text = "..."
    removeBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
            for _, v in ipairs(obj:GetChildren()) do
                if v:IsA("Decal") or v:IsA("Texture") or v:IsA("SurfaceAppearance") then
                    v:Destroy()
                end
            end
            obj.Material = Enum.Material.Plastic
            obj.Color = Color3.fromRGB(100, 100, 100)
        end
    end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            local char = plr.Character
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Accessory") or v:IsA("Hat") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("Clothing") then
                    v:Destroy()
                end
            end
            local head = char:FindFirstChild("Head")
            if head then
                for _, v in ipairs(head:GetChildren()) do
                    if v:IsA("Decal") and string.lower(v.Name) ~= "face" then
                        v:Destroy()
                    end
                end
            end
            for _, part in ipairs(char:GetChildren()) do
                if part:IsA("BasePart") and part.Name ~= "Head" then
                    part.Material = Enum.Material.Plastic
                    part.Color = Color3.fromRGB(163, 162, 165)
                end
            end
        end
    end
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "110c",
        Text = "done",
        Duration = 5
    })
    
    task.wait(1.5)
    removeBtn.Text = "Remove Textures"
    removeBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
end

