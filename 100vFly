SpeedBox.Font = Enum.Font.SourceSans
SpeedBox.TextSize = 13
SpeedBox.Parent = Frame

local flying = false
local connection = nil
local speed = 60

local keys = {W=false, A=false, S=false, D=false, Space=false, Ctrl=false}

local function startFlying()
    humanoid.PlatformStand = true
    
    local bv = Instance.new("BodyVelocity")
    bv.Name = "FlyVelocity"
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = Vector3.new(0,0,0)
    bv.Parent = rootPart
    
    connection = game:GetService("RunService").Heartbeat:Connect(function()
        if not flying then return end
        
        local move = Vector3.new(0, 0, 0)
        local cam = workspace.CurrentCamera
        
        if keys.W then move = move + cam.CFrame.LookVector end
        if keys.S then move = move - cam.CFrame.LookVector end
        if keys.A then move = move - cam.CFrame.RightVector end
        if keys.D then move = move + cam.CFrame.RightVector end
        if keys.Space then move = move + Vector3.new(0,1,0) end
        if keys.Ctrl then move = move - Vector3.new(0,1,0) end
        
        if move.Magnitude > 0 then
            bv.Velocity = move.Unit * speed
        else
            bv.Velocity = Vector3.new(0,0,0)
        end
    end)
end

local function stopFlying()
    flying = false
    if connection then connection:Disconnect() end
    local bv = rootPart:FindFirstChild("FlyVelocity")
    if bv then bv:Destroy() end
    humanoid.PlatformStand = false
end

ToggleButton.MouseButton1Click:Connect(function()
    flying = not flying
    if flying then
        ToggleButton.Text = "Fly ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 220, 100)
        startFlying()
    else
        ToggleButton.Text = "Fly OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 40, 60)
        stopFlying()
    end
end)

game:GetService("UserInputService").InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.W then keys.W = true end
    if input.KeyCode == Enum.KeyCode.S then keys.S = true end
    if input.KeyCode == Enum.KeyCode.A then keys.A = true end
    if input.KeyCode == Enum.KeyCode.D then keys.D = true end
    if input.KeyCode == Enum.KeyCode.Space then keys.Space = true end
    if input.KeyCode == Enum.KeyCode.LeftControl then keys.Ctrl = true end
end)

game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.W then keys.W = false end
    if input.KeyCode == Enum.KeyCode.S then keys.S = false end
    if input.KeyCode == Enum.KeyCode.A then keys.A = false end
    if input.KeyCode == Enum.KeyCode.D then keys.D = false end
    if input.KeyCode == Enum.KeyCode.Space then keys.Space = false end
    if input.KeyCode == Enum.KeyCode.LeftControl then keys.Ctrl = false end
end)

SpeedBox.FocusLost:Connect(function()
    speed = tonumber(SpeedBox.Text) or 60
end)

player.CharacterAdded:Connect(function(newChar)
    task.wait(0.8)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    rootPart = newChar:WaitForChild("HumanoidRootPart")
    if flying then
        flying = false
        ToggleButton.Text = "Fly OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 40, 60)
    end
end)
