				if flyingUp then
					root.CFrame = root.CFrame * CFrame.new(0, 1.5, 0)
				end
				if flyingDown then
					root.CFrame = root.CFrame * CFrame.new(0, -1.5, 0)
				end
			end
		end
	end
end)

